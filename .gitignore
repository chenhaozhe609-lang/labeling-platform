# ---- 规划文档（本地保留，不入库）----
/planning/

# ---- 用户上传的数据 dump（PRD §20.7：绝不入库）----
# 注意：不要用 *.sql 一刀切，否则会误伤 migrations/ 与 source-init/ 等正当 SQL。
# dump 一律落在 uploads/ 或 tmp/，并按扩展名忽略 backup/dump。
*.sql.backup
*.backup
*.dump
/uploads/
/tmp/
/backups/

# ---- 依赖 / 构建产物 ----
node_modules/
dist/
build/
*.log
coverage/

# ---- Go（后端，后续）----
/bin/
*.exe
*.test
*.out
vendor/

# ---- 环境与密钥 ----
.env
.env.*
!.env.example
*.pem
*.key

# ---- 编辑器 / 系统 ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.local

# ---- 前端缓存 ----
web/node_modules/
web/dist/
web/.vite/
.eslintcache
