# 复制为 .env 并按需修改（.env 已被 gitignore）
ENV=dev
# 后端端口 8090（避开 admission 占用的 8080）
HTTP_ADDR=:8090
# meta-db 宿主端口 5442（避开 admission 占用的 5432）
DATABASE_URL=postgres://labeling:labeling@localhost:5442/labeling_meta?sslmode=disable
JWT_SECRET=change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
CORS_ORIGIN=http://localhost:5173

# LLM 预填（OpenAI 兼容；留空 LLM_API_KEY 则用占位 stub，不调用外部）
# DeepSeek: base=https://api.deepseek.com, model=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_TIMEOUT=15s
